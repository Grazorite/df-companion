# Forum session cookie for badge scraping
# To get this:
# 1. Open https://forums2.battleon.com/f/tt.asp?forumid=412 in your browser
# 2. Open DevTools (Cmd+Option+I) → Network tab
# 3. Refresh the page
# 4. Click the first request (tt.asp)
# 5. In the Headers tab, find "Cookie:" in Request Headers
# 6. Copy the full cookie string and paste below

FORUM_COOKIE="paste_your_cookie_string_here"
